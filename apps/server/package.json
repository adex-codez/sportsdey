{
	"name": "server",
	"main": "src/index.ts",
	"type": "module",
	"scripts": {
		"build": "wrangler deploy --dry-run",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server --external @better-auth/expo",
		"dev": "wrangler dev --port=3000",
		"start": "wrangler dev",
		"deploy": "wrangler deploy",
		"db:push": "drizzle-kit push",
		"db:push:staging": "set NODE_ENV=staging&& npx dotenv-cli -e .env.staging -- drizzle-kit push",
		"db:push:prod": "set NODE_ENV=production&& npx dotenv-cli -e .env.production -- drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"admin:create": "node --import tsx src/cli/create-admin.ts",
		"games:seed": "node --import tsx src/cli/seed-games.ts"
	},
	"dependencies": {
		"@better-auth/expo": "^1.4.19",
		"@hono/swagger-ui": "^0.5.2",
		"@hono/zod-openapi": "^1.1.5",
		"@hono/zod-validator": "^0.7.4",
		"@noble/hashes": "^1.6.1",
		"better-auth": "^1.4.19",
		"better-auth-cloudflare": "^0.2.9",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.44.7",
		"hono": "^4.8.2",
		"kysely": "^0.28.11",
		"kysely-d1": "^0.4.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@sportsdey/config": "workspace:*",
		"@types/node": "^22.13.11",
		"tsdown": "catalog:",
		"tsx": "^4.19.0",
		"typescript": "catalog:",
		"wrangler": "catalog:"
	}
}
