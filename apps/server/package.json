{
	"name": "server",
	"main": "src/index.ts",
	"type": "module",
	"scripts": {
		"build": "wrangler deploy --dry-run",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "wrangler dev --port=3000",
		"start": "wrangler dev",
		"deploy": "wrangler deploy",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings"
	},
	"dependencies": {
		"@better-auth/expo": "^1.4.19",
		"@hono/swagger-ui": "^0.5.2",
		"@hono/zod-openapi": "^1.1.5",
		"@hono/zod-validator": "^0.7.4",
		"@sportsdey/db": "workspace:*",
		"better-auth": "^1.4.19",
		"better-auth-cloudflare": "^0.2.9",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.44.7",
		"hono": "^4.8.2",
		"kysely": "^0.28.11",
		"kysely-d1": "^0.4.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@sportsdey/config": "workspace:*",
		"@types/node": "^22.13.11",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"wrangler": "catalog:"
	}
}
